        "    ax.plot([0, len(days)], [y, y], color=\"#cccccc\", linewidth=1, zorder=1)\n",
        "\n",
        "# 각 요일 칸 안에서 사람별 고정 위치\n",
        "day_inner_margin = 0.05\n",
        "usable_width = 0.90\n",
        "lane_gap = 0.02\n",
        "lane_width = (usable_width - 2 * lane_gap) / 3\n",
        "\n",
        "lane_offsets = [\n",
        "    day_inner_margin,\n",
        "    day_inner_margin + lane_width + lane_gap,\n",
        "    day_inner_margin + 2 * (lane_width + lane_gap)\n",
        "]\n",
        "\n",
        "# 수업 박스 그리기\n",
        "for person_idx, person in enumerate(people):\n",
        "    for day, start, end, title in person[\"classes\"]:\n",
        "        x = day_to_x[day] + lane_offsets[person_idx]\n",
        "        y = start\n",
        "        w = lane_width\n",
        "        h = end - start\n",
        "\n",
        "        rect = Rectangle(\n",
        "            (x, y),\n",
        "            w,\n",
        "            h,\n",
        "            facecolor=person[\"color\"],\n",
        "            edgecolor=\"#555555\",\n",
        "            linewidth=1.1,\n",
        "            alpha=0.90,\n",
        "            zorder=2\n",
        "        )\n",
        "        ax.add_patch(rect)\n",
        "\n",
        "        # 높이에 따라 글자 크기 조절\n",
        "        if h < 1.0:\n",
        "            fontsize = 8\n",
        "        elif h < 2.0:\n",
        "            fontsize = 9\n",
        "        else:\n",
        "            fontsize = 10\n",
        "\n",
        "        ax.text(\n",
        "            x + w / 2,\n",
        "            y + h / 2,\n",
        "            f\"{title}\\n({person['short']})\",\n",
        "            ha=\"center\",\n",
        "            va=\"center\",\n",
        "            fontsize=fontsize,\n",
        "            wrap=True,\n",
        "            zorder=3\n",
        "        )\n",
        "\n",
        "# 축 설정\n",
        "ax.set_xlim(0, len(days))\n",
        "ax.set_ylim(end_hour, start_hour)\n",
        "ax.set_xticks([i + 0.5 for i in range(len(days))])\n",
        "ax.set_xticklabels(days, fontsize=14)\n",
        "\n",
        "ax.set_yticks(range(start_hour, end_hour + 1))\n",
        "ax.set_yticklabels([f\"{h}:00\" for h in range(start_hour, end_hour + 1)], fontsize=12)\n",
        "\n",
        "ax.set_title(\"3명 겹친 시간표\", fontsize=20, pad=16)\n",
        "\n",
        "# 범례\n",
        "legend_lines = [f\"{p['short']} = {p['name']}\" for p in people]\n",
        "legend_text = \"   \".join(legend_lines)\n",
        "fig.text(0.5, 0.03, legend_text, ha=\"center\", fontsize=11)\n",
        "\n",
        "# 공강 요약\n",
        "free_summary_lines = []\n",
        "for day in days:\n",
        "    slots = all_free_times[day]\n",
        "    if slots:\n",
        "        text = \", \".join([f\"{format_time(s)}-{format_time(e)}\" for s, e in slots])\n",
        "    else:\n",
        "        text = \"공강 없음\"\n",
        "    free_summary_lines.append(f\"{day}: {text}\")\n",
        "\n",
        "summary_text = \"\\n\".join(free_summary_lines)\n",
        "fig.text(0.02, 0.03, summary_text, fontsize=10, va=\"bottom\")\n",
        "\n",
        "plt.tight_layout(rect=[0, 0.08, 1, 1])\n",
        "\n",
        "save_path = \"/content/merged_timetable_clean.png\"\n",
